    "type": "module",
    "exports": {
        ".": "./shim/index.js",
        "./shim": "./shim/index.js",
        "./shim/index.js": "./shim/index.js",
        "./shim/with-selector": "./shim/with-selector.js",
        "./shim/with-selector.js": "./shim/with-selector.js",
        "./with-selector": "./with-selector.js",
        "./with-selector.js": "./with-selector.js",
        "./package.json": "./package.json"
    },
    "peerDependencies": {
        "react": "^19.0.0"
    }
}
