<?xml version="1.0" encoding="utf-8" ?>
<widget id="com.mendix.finch.widget.group.Group" pluginWidget="true" offlineCapable="false" xmlns="http://www.mendix.com/widget/1.0/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.mendix.com/widget/1.0/ ../node_modules/mendix/custom_widget.xsd">
    <name>Group</name>
    <description>Compose elements and components in a horizontal flex container</description>
    <studioProCategory>Finch</studioProCategory>
    <studioCategory />
    <helpUrl />
    <properties>
        <propertyGroup caption="General">
            <property key="children" type="widgets" required="false">
                <caption>Children</caption>
                <description>Group content</description>
            </property>
            <property key="gap" type="string" required="false" defaultValue="md">
                <caption>Gap</caption>
                <description>Key of theme.spacing or any valid CSS value for gap</description>
            </property>
            <property key="justify" type="string" required="false" defaultValue="flex-start">
                <caption>Justify</caption>
                <description>Controls justify-content CSS property</description>
            </property>
            <property key="align" type="string" required="false" defaultValue="center">
                <caption>Align</caption>
                <description>Controls align-items CSS property</description>
            </property>
            <property key="wrap" type="enumeration" required="true" defaultValue="wrap">
                <caption>Wrap</caption>
                <description>Controls flex-wrap CSS property</description>
                <enumerationValues>
                    <enumerationValue key="nowrap">No wrap</enumerationValue>
                    <enumerationValue key="wrap">Wrap</enumerationValue>
                    <enumerationValue key="wrapReverse">Wrap reverse</enumerationValue>
                </enumerationValues>
            </property>
        </propertyGroup>
    </properties>
</widget>
