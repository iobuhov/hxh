        "@mantine/hooks": "catalog:",
        "@mendix/finch-chart-utils": "workspace:*",
        "@mendix/prettier-config-web-widgets": "workspace:*",
        "@mendix/yaml-to-xml-converter": "workspace:*",
        "classnames": "catalog:",
        "mendix": "catalog:",
        "mpx": "*",
        "recharts": "catalog:"
    },
    "prettier": "@mendix/prettier-config-web-widgets"
}
