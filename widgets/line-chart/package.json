{
    "name": "@mendix/line-chart",
    "widgetName": "LineChart",
    "version": "0.1.0",
    "description": "Line chart with one or more data series over a shared category axis",
    "copyright": "© 2025 Illia Obukhau",
    "author": "Illia Obukhau",
    "engines": {
        "node": ">=22"
    },
    "license": "Apache-2.0",
    "config": {},
    "packagePath": "com.mendix.finch.widget",
    "scripts": {
        "build": "mpx",
        "dev": "mpx -w",
        "lint": "pluggable-widgets-tools lint",
        "test": "pluggable-widgets-tools test:unit:web --no-cache --ci",
        "test:unit": "pluggable-widgets-tools test:unit:web --coverage",
        "update-xml": "yaml-to-xml src/line-chart.yaml src/LineChart.xml"
