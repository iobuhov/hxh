<?xml version="1.0" encoding="utf-8" ?>
<widget id="com.mendix.finch.widget.lucideicon.LucideIcon" pluginWidget="true" offlineCapable="false" xmlns="http://www.mendix.com/widget/1.0/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.mendix.com/widget/1.0/ ../node_modules/mendix/custom_widget.xsd">
    <name>LucideIcon</name>
    <description>Renders a Lucide icon by name</description>
    <studioProCategory>Finch</studioProCategory>
    <studioCategory />
    <helpUrl />
    <properties>
        <propertyGroup caption="General">
            <property key="icon" type="string" required="false" defaultValue="circle">
                <caption>Icon</caption>
                <description>Lucide icon name (e.g. "layout-dashboard", "shopping-cart")</description>
            </property>
            <property key="size" type="integer" required="true" defaultValue="20">
                <caption>Size</caption>
                <description>Icon size in pixels</description>
            </property>
            <property key="color" type="string" required="false">
                <caption>Color</caption>
                <description>Icon color (CSS value, defaults to currentColor)</description>
            </property>
            <property key="strokeWidth" type="string" required="false" defaultValue="2">
                <caption>Stroke Width</caption>
                <description>Icon stroke width</description>
            </property>
        </propertyGroup>
        <propertyGroup caption="Theme Icon">
            <property key="themeIcon" type="boolean" required="true" defaultValue="false">
                <caption>Theme Icon</caption>
                <description>Wrap icon in a ThemeIcon container</description>
            </property>
            <property key="themeIconVariant" type="string" required="false" defaultValue="light">
                <caption>Variant</caption>
                <description>ThemeIcon variant (light, filled, outline, subtle, gradient)</description>
            </property>
            <property key="themeIconColor" type="string" required="false" defaultValue="gray">
                <caption>Color</caption>
                <description>ThemeIcon color</description>
            </property>
            <property key="themeIconSize" type="string" required="false" defaultValue="sm">
                <caption>Size</caption>
                <description>ThemeIcon size (xs, sm, md, lg, xl)</description>
            </property>
        </propertyGroup>
        <propertyGroup caption="Common">
            <systemProperty key="Visibility" />
        </propertyGroup>
    </properties>
</widget>
