<?xml version="1.0" encoding="utf-8" ?>
<widget id="com.mendix.finch.widget.text.Text" pluginWidget="true" offlineCapable="false" xmlns="http://www.mendix.com/widget/1.0/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.mendix.com/widget/1.0/ ../node_modules/mendix/custom_widget.xsd">
    <name>Text</name>
    <description>Display text</description>
    <studioProCategory>Finch</studioProCategory>
    <studioCategory />
    <helpUrl />
    <properties>
        <propertyGroup caption="General">
            <property key="text" type="textTemplate" required="false">
                <caption>Text</caption>
                <description>Text content</description>
            </property>
            <property key="size" type="string" required="false" defaultValue="md">
                <caption>Size</caption>
                <description>Controls font-size and line-height</description>
            </property>
            <property key="color" type="string" required="false">
                <caption>Color</caption>
                <description>Text color (e.g. dimmed, red, blue)</description>
            </property>
            <property key="fw" type="string" required="false">
                <caption>Font Weight</caption>
                <description>Font weight (e.g. 500, 700, bold)</description>
            </property>
            <property key="truncate" type="enumeration" required="true" defaultValue="none">
                <caption>Truncate</caption>
                <description>Truncate overflowing text with an ellipsis on the given side</description>
                <enumerationValues>
                    <enumerationValue key="none">None</enumerationValue>
                    <enumerationValue key="end">End</enumerationValue>
                    <enumerationValue key="start">Start</enumerationValue>
                </enumerationValues>
            </property>
            <property key="slot" type="enumeration" required="true" defaultValue="none">
                <caption>Slot</caption>
                <description>Slot name for ARIA context</description>
                <enumerationValues>
                    <enumerationValue key="none">None</enumerationValue>
                    <enumerationValue key="label">Label</enumerationValue>
                </enumerationValues>
            </property>
        </propertyGroup>
    </properties>
</widget>
